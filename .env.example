# MCQ Hedge Fund Agent — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mcq_hedgefund
# Or for Google Sheets (MVP mode):
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=

# ─── AI / LLM ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Token budget per agent cycle (tokenjuice integration)
MCQ_TOKEN_BUDGET_PER_CYCLE=50000

# ─── Market Data ────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
POLYGON_IO_API_KEY=
YFINANCE_ENABLED=true

# ─── On-chain / Agent Pay ───────────────────────────────────────
# Mastercard Agent Pay for Machines
MASTERCARD_AP4M_CLIENT_ID=
MASTERCARD_AP4M_CLIENT_SECRET=
MASTERCARD_AP4M_ENVIRONMENT=sandbox

# Ripple / XRPL
XRPL_NETWORK=mainnet
XRPL_WALLET_ADDRESS=
XRPL_WALLET_SECRET=
RLUSD_CONTRACT_ADDRESS=

# ─── Governance Engine ──────────────────────────────────────────
# Baseline hazard rate (calibrate from historical data)
GOV_H0=0.05
GOV_BETA_G=1.5
GOV_BETA_VELOCITY=0.4
GOV_BETA_VOLUME=0.3
GOV_BETA_SHADOW=0.6
# Fractional Kelly safety factor
KELLY_FRACTION_FACTOR=0.25

# ─── Auth ───────────────────────────────────────────────────────
JWT_SECRET=
ADMIN_USER_EMAIL=

# ─── Infra ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
