# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Governance / Hazard model coefficients ───────────────────────────────────
H0=0.01
BETA_G=1.5
BETA_VELOCITY=0.8
BETA_VOLUME=0.5
BETA_SHADOW=1.2

# ─── Kelly sizing ─────────────────────────────────────────────────────────────
FRACTIONAL_KELLY=0.25

# ─── Kalshi API ───────────────────────────────────────────────────────────────
# Demo base URL: https://external-api.demo.kalshi.co
# Prod base URL: https://trading-api.kalshi.com
KALSHI_BASE_URL=https://external-api.demo.kalshi.co
KALSHI_API_KEY_ID=your-key-id-here
# Path to your RSA private key PEM file — NEVER commit the actual key file
KALSHI_PRIVATE_KEY_PATH=/run/secrets/kalshi_private_key.pem
# OR paste PEM as a single env var in your secret manager (newlines as \n):
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
