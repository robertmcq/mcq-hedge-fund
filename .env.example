# MCQ Hedge Fund Agent — Environment Variable Template
# Copy to .env and fill in values. Never commit .env to version control.
# All variables have coded defaults; the app runs without this file.
# See SYSTEM_STATUS.md for which modules consume each variable.

# =============================================================================
# GOVERNANCE ENGINE (src/governance/)
# =============================================================================

# Baseline hazard rate (h₀) — default 0.05
GOV_BASELINE_HAZARD=0.05

# Beta coefficients for hazard covariates
GOV_BETA_G=1.5
GOV_BETA_VELOCITY=0.8
GOV_BETA_VOLUME=0.6
GOV_BETA_SHADOW=1.2

# Fractional Kelly multiplier (0–1.0) — default 0.25
KELLY_FRACTION_FACTOR=0.25

# Governance alert thresholds (hazard rate)
GOV_ALERT_WARN=0.10
GOV_ALERT_HIGH=0.25
GOV_ALERT_CRITICAL=0.50

# =============================================================================
# CAPM INPUTS (src/panels/panel1-dcf/dividend-screen.ts)
# Reference inputs: Jul 2026 — R_f=4.65%, R_m=10%, MRP=5.35%
# =============================================================================

CAPM_RF=0.0465
CAPM_RM=0.10
CAPM_BETA=0.8

# =============================================================================
# DIVIDEND INCOME SLEEVE (src/integrations/dividend-calendar.ts)
# =============================================================================

# Market data provider: polygon (default) or iex
DIVIDEND_API_PROVIDER=polygon

# API key for chosen provider
DIVIDEND_API_KEY=your_polygon_or_iex_api_key_here

# Income sleeve screening thresholds
INCOME_YIELD_FLOOR=2.5
INCOME_PAYOUT_MAX_EARNINGS=75
INCOME_PAYOUT_MAX_FCF=90
INCOME_GROWTH_STREAK_MIN=5

# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL=postgresql://user:password@localhost:5432/mcq

# =============================================================================
# API SERVER
# =============================================================================

PORT=3000
NODE_ENV=development

# =============================================================================
# AUTH / ROLES
# Roles: PM | RISK | ANALYST | OPS | READONLY
# =============================================================================

JWT_SECRET=your_jwt_secret_here
DEFAULT_ROLE=READONLY

# =============================================================================
# MARKET DATA (general)
# =============================================================================

POLYGON_API_KEY=your_polygon_api_key_here
IEX_API_KEY=your_iex_api_key_here

# =============================================================================
# AGENT PAY INTEGRATION (planned)
# =============================================================================

# MASTERCARD_AGENT_PAY_KEY=
# XRPL_WALLET_SEED=
# ONCHAIN_RPC_URL=
