# =============================================================================
# MCQ Hedge Fund — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# Production: all secrets injected from AWS Secrets Manager via ECS task definition.
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── API Authentication ───────────────────────────────────────────────────────
# All routes (except /api/health) require x-api-key: <value>
# Set in AWS Secrets Manager as: MCQ_HEDGE_FUND_API_KEY
API_KEY=REPLACE_ME

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ─── Database (AWS RDS Postgres) ──────────────────────────────────────────────
# Local dev: use a local Postgres instance
# Production: injected from Secrets Manager — never hardcode
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://mcq_user:changeme@localhost:5432/mcq_fund

# ─── Governance / Hazard model coefficients ───────────────────────────────────
H0=0.01
BETA_G=1.5
BETA_VELOCITY=0.8
BETA_VOLUME=0.5
BETA_SHADOW=1.2

# ─── Kelly sizing ─────────────────────────────────────────────────────────────
FRACTIONAL_KELLY=0.25

# ─── Kalshi REST API (production) ─────────────────────────────────────────────
KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=REPLACE_ME

# ─── Kalshi WebSocket (production) ────────────────────────────────────────────
KALSHI_WS_URL=wss://external-api-ws.kalshi.com/trade-api/ws/v2

# ─── Kalshi market subscriptions (comma-separated tickers) ────────────────────
KALSHI_TICKERS=KXBTC-26DEC31-B100000,KXINX-26DEC31-T5000

# ─── Kalshi private key (RSA) — NEVER commit the actual key ───────────────────
# Production: inject via AWS Secrets Manager as KALSHI_PRIVATE_KEY_PEM
# The key is pulled at runtime — no file path dependency in production
#
# Local dev only — option A: PEM string
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
#
# Local dev only — option B: path to key file
# KALSHI_PRIVATE_KEY_PATH=/path/to/local/kalshi_private_key.pem
