# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Postgres ─────────────────────────────────────────────────────────────────
# Railway: set this in your app service Variables tab as:
#   DATABASE_URL=${{MCQ fund test run.DATABASE_URL}}
# Local: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://mcq_user:changeme@localhost:5432/mcq_fund

# ─── Governance / Hazard model coefficients ───────────────────────────────────
H0=0.01
BETA_G=1.5
BETA_VELOCITY=0.8
BETA_VOLUME=0.5
BETA_SHADOW=1.2

# ─── Kelly sizing ─────────────────────────────────────────────────────────────
FRACTIONAL_KELLY=0.25

# ─── Kalshi REST API (production) ─────────────────────────────────────────────
KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=your-production-key-id-here

# ─── Kalshi WebSocket (production) ────────────────────────────────────────────
KALSHI_WS_URL=wss://external-api-ws.kalshi.com/trade-api/ws/v2

# ─── Kalshi market subscriptions (comma-separated tickers) ───────────────────
KALSHI_TICKERS=KXBTC-26DEC31-B100000,KXINX-26DEC31-T5000

# ─── Kalshi private key (RSA) — NEVER commit the actual key ──────────────────
# Option A: inject PEM as a secret (newlines as \n):
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
#
# Option B: path to key file (Docker secret / mounted volume):
KALSHI_PRIVATE_KEY_PATH=/run/secrets/kalshi_private_key.pem

# ─── Docker secret key file path (used by docker-compose.yml) ────────────────
KALSHI_KEY_FILE=/run/secrets/kalshi_key.pem
