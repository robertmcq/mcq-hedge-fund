# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Postgres ─────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://mcq_user:changeme@localhost:5432/mcq_fund

# ─── Governance / Hazard model coefficients ───────────────────────────────────
H0=0.01
BETA_G=1.5
BETA_VELOCITY=0.8
BETA_VOLUME=0.5
BETA_SHADOW=1.2

# ─── Kelly sizing ─────────────────────────────────────────────────────────────
FRACTIONAL_KELLY=0.25

# ─── Kalshi REST API ──────────────────────────────────────────────────────────
# Demo: https://external-api.demo.kalshi.co
# Prod: https://trading-api.kalshi.com
KALSHI_BASE_URL=https://external-api.demo.kalshi.co
KALSHI_API_KEY_ID=your-key-id-here

# ─── Kalshi WebSocket ─────────────────────────────────────────────────────────
# Demo: wss://external-api-ws.demo.kalshi.co/trade-api/ws/v2
# Prod: wss://external-api-ws.kalshi.com/trade-api/ws/v2
KALSHI_WS_URL=wss://external-api-ws.demo.kalshi.co/trade-api/ws/v2

# ─── Kalshi private key (RSA) — NEVER commit the actual key ───────────────────
# Option A: inject PEM as a secret (newlines as \n):
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
#
# Option B: path to key file (Docker secret / mounted volume):
KALSHI_PRIVATE_KEY_PATH=/run/secrets/kalshi_private_key.pem
