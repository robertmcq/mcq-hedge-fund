{
  "name": "mcq-hedge-fund",
  "version": "1.0.0",
  "description": "MCQ Hedge Fund — five-panel decision console with Kalshi feed and Postgres governance layer",
  "private": true,
  "engines": { "node": ">=22" },
  "scripts": {
    "build":   "tsc --project tsconfig.build.json",
    "dev":     "ts-node --esm src/api/server.ts",
    "start":   "node dist/api/server.js",
    "seed":    "ts-node src/scripts/seed-portfolio.ts",
    "test":    "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint":    "eslint 'src/**/*.ts' --max-warnings 0"
  },
  "dependencies": {
    "express":      "^4.19.2",
    "pg":           "^8.12.0",
    "uuid":         "^10.0.0",
    "ws":           "^8.17.1",
    "dotenv":       "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node":    "^22.0.0",
    "@types/pg":      "^8.11.6",
    "@types/uuid":    "^10.0.0",
    "@types/ws":      "^8.5.12",
    "typescript":     "^5.5.3",
    "ts-node":        "^10.9.2",
    "vitest":         "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
